# markspace - API keys for LLM experiments
#
# Copy this file to .env and fill in your keys.
# The reference implementation (core, guard, tests) does not require any API keys.
# Keys are only needed to run the LLM-driven experiments.

# Primary provider: Fireworks (checked first)
FIREWORKS_API_TOKEN=

# Alternative provider: OpenAI (used if no Fireworks key is set)
# OPENAI_API_KEY=

# Alternative provider: Google Gemini (OpenAI-compatible endpoint)
# GEMINI_API_KEY=

# Alternative provider: Anthropic Claude (OpenAI-compatible endpoint)
# ANTHROPIC_API_KEY=

# Optional: custom Fireworks endpoint
# FIREWORKS_INFERENCE_ENDPOINT=

# Optional: Inception Labs (only needed for mercury-2 model)
# INCEPTION_API_KEY=
